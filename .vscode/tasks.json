{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/IronRose.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/maxcpucount:4",
                "/nodeReuse:false"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
